generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  address     String?
  billingInfo String?
  users       User[]
  roles       AuthRole[]
  companies   Company[]
  contacts    Contact[]
  deals       Deal[]
  tasks       Task[]
  notes       Note[]
  auditLogs   AuditLog[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("aae_organizations")
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  username         String?        @unique
  phone            String?
  passwordHash     String
  firstName        String
  lastName         String
  role             String
  status           String         @default("invited")
  emailVerified    Boolean        @default(false)
  failedLoginAttempts Int         @default(0)
  lockoutEnd       DateTime?
  orgId            String?
  organization     Organization?  @relation(fields: [orgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lastLogin        DateTime?
  twoFactorEnabled Boolean        @default(false)
  createdBy        String?
  updatedBy        String?
  refreshTokens    RefreshToken[]
  userRoles        UserRole[]
  loginHistory     LoginHistory[]
  passwordHistory  PasswordHistory[]
  emailVerifications EmailVerification[]
  passwordResetTokens PasswordResetToken[]
  sessions         UserSession[]
  ownedDeals       Deal[]         @relation("DealOwner")
  assignedTasks    Task[]         @relation("TaskAssignee")
  notes            Note[]
  auditLogs        AuditLog[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([orgId])
  @@map("aae_users")
}

model AuthRole {
  id             String           @id @default(cuid())
  orgId          String?
  org            Organization?    @relation(fields: [orgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  name           String
  description    String?
  priority       Int              @default(100)
  isSystemRole   Boolean          @default(false)
  rolePermissions RolePermission[]
  userRoles      UserRole[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([orgId, name])
  @@map("aae_roles")
}

model Permission {
  id              String           @id @default(cuid())
  module          String
  action          String
  displayName     String
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())

  @@unique([module, action])
  @@map("aae_permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         AuthRole   @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("aae_role_permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roleId    String
  role      AuthRole @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedBy String?
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("aae_user_roles")
}

model Company {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  name      String
  industry  String?
  address   String?
  phone     String?
  website   String?
  contacts  Contact[]
  deals     Deal[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([orgId])
  @@map("aae_companies")
}

model Contact {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId String?
  company   Company?     @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  firstName String
  lastName  String
  email     String?
  phone     String?
  role      String?
  deals     Deal[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([orgId])
  @@index([companyId])
  @@map("aae_contacts")
}

model Deal {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId   String?
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contactId   String?
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title       String
  description String?
  amount      Decimal      @default(0)
  currency    String       @default("USD")
  stage       String       @default("prospecting")
  probability Int          @default(10)
  ownerId     String
  owner       User         @relation("DealOwner", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  closeDate   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([orgId, stage])
  @@index([ownerId])
  @@map("aae_deals")
}

model Task {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title       String
  description String?
  dueDate     DateTime?
  status      String       @default("open")
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  relatedType String?
  relatedId   String?
  priority    String       @default("medium")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([orgId, status])
  @@index([assigneeId])
  @@map("aae_tasks")
}

model Note {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  relatedType String
  relatedId   String
  content     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([orgId, relatedType, relatedId])
  @@map("aae_notes")
}

model AuditLog {
  id         String       @id @default(cuid())
  orgId      String?
  org        Organization? @relation(fields: [orgId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId     String?
  user       User?        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  action     String
  module     String?
  objectType String
  objectId   String?
  oldValue   String?
  newValue   String?
  diff       String?
  ip         String?
  userAgent  String?
  browser    String?
  os         String?
  device     String?
  createdAt  DateTime     @default(now())

  @@index([orgId, objectType])
  @@map("aae_audit_logs")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tokenHash String
  revoked   Boolean  @default(false)
  rememberMe Boolean @default(false)
  userAgent String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@map("aae_refresh_tokens")
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  email     String
  success   Boolean
  reason    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@map("aae_login_history")
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("aae_password_history")
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tokenHash String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("aae_email_verifications")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tokenHash String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("aae_password_reset_tokens")
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  refreshTokenId String?
  ip          String?
  userAgent   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("aae_user_sessions")
}
